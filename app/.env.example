# ─────────────────────────────────────────────────────────────────────────────
# LLM provider key (REQUIRED) — the active `provider:` in app/config.yaml decides
# which key every LLM call uses. Default provider is `groq`.
# ─────────────────────────────────────────────────────────────────────────────

# Groq (default) — used by every LLM call when provider: groq.
# init_chat_model(model_provider="groq"). Free tier is large (~14,400 req/day on
# llama-3.1-8b-instant), so multi-step runs finish without hitting a daily cap.
# Get a key at https://console.groq.com/keys  (keys start with `gsk_`).
GROQ_API_KEY=your-groq-api-key

# Google Gemini (alternate) — used only when provider: gemini in app/config.yaml.
# init_chat_model(model_provider="google_genai"). Free tier is ~20 req/day, which a
# single multi-step task exhausts; prefer a paid key if you switch to gemini.
GOOGLE_API_KEY=your-gemini-api-key

# Tavily (strongly recommended) — grounded web-search backend for the Research Agent.
# Without it, research is ungrounded. Get a key at https://app.tavily.com.
TAVILY_API_KEY=your-tavily-api-key